# Copy this file to `.env` at the project root to centralize Docker Compose settings.

# App ports
FRONTEND_PORT=3000
FRONTEND_HOST_PORT=3000
BACKEND_PORT=3001
BACKEND_HOST_PORT=3001
MYSQL_HOST_PORT=3306

# Backend / app
DB_USER=app_user
DB_PASSWORD=change_me
DB_NAME=gestao_metas
DB_CONNECT_STRING=oracle-host:1521/service_name
ADMIN_RESET_TOKEN=change_me
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1
N8N_ATIVACAO_WEBHOOK=

# Local MySQL
MYSQL_DATABASE=gestao_metas
MYSQL_USER=app_user
MYSQL_PASSWORD=change_me
MYSQL_ROOT_PASSWORD=root_change_me
