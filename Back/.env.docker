NODE_ENV=production
PORT=3001
CORS_ORIGINS=http://localhost:3002

# Auth JWT
# Troque este valor no servidor depois do primeiro deploy.
AUTH_TOKEN_SECRET=troque-por-string-aleatoria-de-32-chars-em-producao
AUTH_TOKEN_TTL_SECONDS=43200
AUTH_COOKIE_NAME=sip_auth
AUTH_COOKIE_SAME_SITE=lax

# Criptografia de senhas Oracle
# Troque este valor no servidor depois do primeiro deploy.
APP_ENCRYPTION_KEY=1111111111111111111111111111111111111111111111111111111111111111

# Oracle legado
DB_USER=DM_VENDAS
DB_PASSWORD=DADOS
DB_CONNECT_STRING=172.30.0.175:1521/bipdb
ENABLE_ORACLE_LOGIN_FALLBACK=false
ORACLE_TENANT_PASSWORD_FALLBACK=DADOS

# MySQL central da aplicacao em Docker Compose.
MYSQL_HOST=mysql
MYSQL_PORT=3306
MYSQL_USER=app_user
MYSQL_PASSWORD=santri@123
MYSQL_DATABASE=gestao_metas

# MySQL admin para criar databases tenant.
MYSQL_ADMIN_HOST=mysql
MYSQL_ADMIN_PORT=3306
MYSQL_ADMIN_USER=root
MYSQL_ADMIN_PASSWORD=root_change_me
MYSQL_ROOT_PASSWORD=root_change_me
MYSQL_GRANT_USER=app_user
MYSQL_USER_HOST=10.100.10.%
MYSQL_TENANT_GRANT_PRIVILEGES=SELECT, INSERT, UPDATE, DELETE

# Superadmin inicial
SUPERADMIN_INITIAL_LOGIN=admin
SUPERADMIN_INITIAL_PASSWORD=troque-essa-senha

# Integracoes
ADMIN_RESET_TOKEN=token-para-reset-em-massa
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1
N8N_ATIVACAO_WEBHOOK=

# Producao
ALLOW_DESTRUCTIVE_ORG_DELETE=false

# Jobs Prefect
PREFECT_VALIDATION_INTERVAL_SECONDS=1800
