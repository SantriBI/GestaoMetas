NODE_ENV=development
PORT=3001
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:3002,http://127.0.0.1:3002

# ── Auth JWT ──────────────────────────────────────────────────────────────────
AUTH_TOKEN_SECRET=troque-por-string-aleatoria-de-32-chars-em-producao
AUTH_TOKEN_TTL_SECONDS=43200
AUTH_COOKIE_NAME=sip_auth
AUTH_COOKIE_SAME_SITE=lax

# ── Criptografia de senhas Oracle ─────────────────────────────────────────────
# Gere com: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
APP_ENCRYPTION_KEY=gere-uma-chave-hex-de-64-caracteres

# ── Oracle (conexao padrao do sistema legado) ─────────────────────────────────
DB_USER=DM_VENDAS
DB_PASSWORD=DADOS
DB_CONNECT_STRING=172.30.0.175:1521/bipdb
ENABLE_ORACLE_LOGIN_FALLBACK=false

# Modo do node-oracledb: auto, thin ou thick.
# Use thick quando o Oracle exigir Native Network Encryption/Data Integrity
# (erro NJS-533 em thin mode). No Docker, o Dockerfile ja define thick.
ORACLE_CLIENT_MODE=thick
ORACLE_REQUIRE_THICK=true

# Caminho local do Oracle Instant Client.
# Windows/macOS: pode apontar para a pasta extraida.
# Linux/Docker: nao use libDir; configure ldconfig ou LD_LIBRARY_PATH antes
# de iniciar o Node.js e use ORACLE_CLIENT_MODE=thick.
# Exemplo Windows: ORACLE_CLIENT_LIB_DIR=C:\instantclient_23_5
ORACLE_CLIENT_LIB_DIR=

# ── MySQL Central (autenticacao e admin) ──────────────────────────────────────
MYSQL_HOST=172.22.0.39
MYSQL_PORT=3307
MYSQL_USER=app_user
MYSQL_PASSWORD=app_password
MYSQL_DATABASE=gestao_metas
MYSQL_CONNECT_TIMEOUT_MS=5000

# ── MySQL Admin (para criar databases tenant) ──────────────────────────────────
MYSQL_ADMIN_HOST=172.22.0.39
MYSQL_ADMIN_PORT=3307
MYSQL_ADMIN_USER=root
MYSQL_ADMIN_PASSWORD=root_password
MYSQL_ROOT_PASSWORD=root_password
MYSQL_GRANT_USER=app_user
MYSQL_USER_HOST=%
MYSQL_TENANT_GRANT_PRIVILEGES=SELECT, INSERT, UPDATE, DELETE

# ── Superadmin inicial (criado automaticamente na primeira inicializacao) ──────
SUPERADMIN_INITIAL_LOGIN=admin
SUPERADMIN_INITIAL_PASSWORD=troque-essa-senha

# ── Integrações ───────────────────────────────────────────────────────────────
ADMIN_RESET_TOKEN=token-para-reset-em-massa
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1
N8N_ATIVACAO_WEBHOOK=

# ── Producao ──────────────────────────────────────────────────────────────────
ALLOW_DESTRUCTIVE_ORG_DELETE=false

# Jobs Prefect
PREFECT_VALIDATION_INTERVAL_SECONDS=1800

# ── Evolution API — Integração WhatsApp ────────────────────────────────────────
EVOLUTION_API_URL=http://localhost:8080
EVOLUTION_API_KEY=sua-global-apikey-aqui
EVOLUTION_DELAY_MIN_MS=8000
EVOLUTION_DELAY_MAX_MS=15000
