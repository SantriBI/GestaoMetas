# Copie este arquivo para ".env" e preencha com valores reais antes de rodar "npm run qa".

# URL onde o frontend (Next.js) esta rodando. As chamadas /api/* passam pelo
# rewrite do next.config.mjs ate o backend, entao normalmente so esta variavel basta.
BASE_URL=http://localhost:3000

# Rodar com navegador visivel (false) ou headless (true, padrao em CI).
HEADLESS=true

# Timeouts em milissegundos.
DEFAULT_TIMEOUT_MS=15000
ACTION_TIMEOUT_MS=10000
NAVIGATION_TIMEOUT_MS=30000

# Reduz a velocidade das acoes (uteis para depurar visualmente, 0 = desligado).
SLOWMO_MS=0

# Quantidade de workers em paralelo (deixe em branco para o Playwright decidir).
WORKERS=

# Credenciais de um usuario de teste GERENTE (ideal: organizacao/tenant de teste, nao producao).
QA_GERENTE_LOGIN=
QA_GERENTE_SENHA=

# Credenciais de um usuario de teste VENDEDOR.
QA_VENDEDOR_LOGIN=
QA_VENDEDOR_SENHA=
